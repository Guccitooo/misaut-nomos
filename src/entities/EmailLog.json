{
  "name": "EmailLog",
  "type": "object",
  "properties": {
    "to_email": {
      "type": "string",
      "description": "Email del destinatario"
    },
    "user_id": {
      "type": "string",
      "description": "ID del usuario si aplica"
    },
    "subject": {
      "type": "string",
      "description": "Asunto del email"
    },
    "template": {
      "type": "string",
      "description": "Nombre del template usado"
    },
    "category": {
      "type": "string",
      "enum": ["transactional", "marketing"],
      "description": "Tipo de email"
    },
    "status": {
      "type": "string",
      "enum": ["queued", "sent", "delivered", "opened", "clicked", "bounced", "spam", "failed", "skipped"],
      "default": "queued",
      "description": "Estado del email"
    },
    "resend_message_id": {
      "type": "string",
      "description": "ID del mensaje en Resend"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time",
      "description": "Cuándo se envió"
    },
    "delivered_at": {
      "type": "string",
      "format": "date-time",
      "description": "Cuándo se entregó"
    },
    "opened_at": {
      "type": "string",
      "format": "date-time",
      "description": "Cuándo se abrió por primera vez"
    },
    "clicked_at": {
      "type": "string",
      "format": "date-time",
      "description": "Cuándo se hizo clic en un enlace"
    },
    "bounced_at": {
      "type": "string",
      "format": "date-time",
      "description": "Cuándo rebotó"
    },
    "error_message": {
      "type": "string",
      "description": "Mensaje de error si falló"
    },
    "metadata": {
      "type": "object",
      "description": "Datos adicionales",
      "default": {}
    }
  },
  "required": ["to_email", "subject", "template", "category"],
  "security": {
    "read": {
      "rule": "auth.role == 'admin'"
    },
    "create": {
      "rule": "authenticated"
    },
    "update": {
      "rule": "auth.role == 'admin'"
    },
    "delete": {
      "rule": "auth.role == 'admin'"
    }
  },
  "indexes": [
    {
      "fields": ["to_email", "created_date"]
    },
    {
      "fields": ["resend_message_id"]
    },
    {
      "fields": ["user_id", "status"]
    },
    {
      "fields": ["status", "created_date"]
    }
  ]
}