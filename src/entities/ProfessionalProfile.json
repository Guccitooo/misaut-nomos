{
  "name": "ProfessionalProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID del usuario profesional"
    },
    "business_name": {
      "type": "string",
      "description": "Nombre comercial"
    },
    "cif_nif": {
      "type": "string",
      "description": "CIF / NIF"
    },
    "email_contacto": {
      "type": "string",
      "description": "Email de contacto"
    },
    "telefono_contacto": {
      "type": "string",
      "description": "Tel\u00e9fono de contacto"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Categor\u00edas de servicios",
      "default": []
    },
    "descripcion_corta": {
      "type": "string",
      "description": "Descripci\u00f3n corta (m\u00e1x 220 caracteres)",
      "default": ""
    },
    "description": {
      "type": "string",
      "description": "Descripci\u00f3n detallada de los servicios",
      "default": ""
    },
    "service_area": {
      "type": "string",
      "description": "Zona de intervenci\u00f3n",
      "default": ""
    },
    "radio_servicio_km": {
      "type": "number",
      "description": "Radio de servicio en kil\u00f3metros",
      "default": 10
    },
    "opening_hours": {
      "type": "string",
      "description": "Horarios de apertura",
      "default": ""
    },
    "tarifa_base": {
      "type": "number",
      "description": "Tarifa base por hora/servicio",
      "default": 0
    },
    "facturacion": {
      "type": "string",
      "enum": [
        "autonomo",
        "sociedad",
        "otros"
      ],
      "description": "Tipo de facturaci\u00f3n",
      "default": "autonomo"
    },
    "formas_pago": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Formas de pago aceptadas",
      "default": []
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs de las fotos de realizaciones",
      "default": []
    },
    "imagen_principal": {
      "type": "string",
      "description": "URL de la imagen principal",
      "default": ""
    },
    "website": {
      "type": "string",
      "description": "Sitio web",
      "default": ""
    },
    "social_links": {
      "type": "object",
      "properties": {
        "facebook": {
          "type": "string"
        },
        "instagram": {
          "type": "string"
        },
        "linkedin": {
          "type": "string"
        }
      },
      "description": "Enlaces de redes sociales",
      "default": {}
    },
    "price_range": {
      "type": "string",
      "enum": [
        "\u20ac",
        "\u20ac\u20ac",
        "\u20ac\u20ac\u20ac"
      ],
      "description": "Gama de precios",
      "default": "\u20ac\u20ac"
    },
    "average_rating": {
      "type": "number",
      "description": "Nota media",
      "default": 0
    },
    "total_reviews": {
      "type": "number",
      "description": "N\u00famero total de opiniones",
      "default": 0
    },
    "estado_perfil": {
      "type": "string",
      "enum": [
        "pendiente",
        "activo",
        "inactivo",
        "suspendido"
      ],
      "description": "Estado del perfil",
      "default": "pendiente"
    },
    "visible_en_busqueda": {
      "type": "boolean",
      "description": "Visible en b\u00fasquedas p\u00fablicas",
      "default": false
    },
    "onboarding_completed": {
      "type": "boolean",
      "description": "Quiz de onboarding completado",
      "default": false
    },
    "fecha_publicacion": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de publicaci\u00f3n del perfil"
    },
    "acepta_terminos": {
      "type": "boolean",
      "description": "Acepta t\u00e9rminos y condiciones",
      "default": false
    },
    "acepta_politica_privacidad": {
      "type": "boolean",
      "description": "Acepta pol\u00edtica de privacidad",
      "default": false
    },
    "consiente_contacto_clientes": {
      "type": "boolean",
      "description": "Consiente contacto de clientes",
      "default": false
    },
    "slug_publico": {
      "type": "string",
      "description": "Slug para URL p\u00fablica"
    }
  },
  "required": [
    "user_id",
    "business_name"
  ]
}