{
  "name": "ProfessionalProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID del usuario profesional"
    },
    "business_name": {
      "type": "string",
      "description": "Nombre comercial",
      "default": ""
    },
    "cif_nif": {
      "type": "string",
      "description": "CIF / NIF",
      "default": ""
    },
    "email_contacto": {
      "type": "string",
      "description": "Email de contacto",
      "default": ""
    },
    "telefono_contacto": {
      "type": "string",
      "description": "Tel\u00e9fono de contacto",
      "default": ""
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Categor\u00edas de servicios",
      "default": []
    },
    "descripcion_corta": {
      "type": "string",
      "description": "Descripci\u00f3n corta (m\u00e1x 220 caracteres)",
      "default": ""
    },
    "description": {
      "type": "string",
      "description": "Descripci\u00f3n detallada de los servicios",
      "default": ""
    },
    "service_area": {
      "type": "string",
      "description": "Zona de intervenci\u00f3n completa",
      "default": ""
    },
    "provincia": {
      "type": "string",
      "description": "Provincia",
      "default": ""
    },
    "ciudad": {
      "type": "string",
      "description": "Ciudad",
      "default": ""
    },
    "municipio": {
      "type": "string",
      "description": "Municipio / Barrio",
      "default": ""
    },
    "radio_servicio_km": {
      "type": "number",
      "description": "Radio de servicio en kil\u00f3metros",
      "default": 10
    },
    "opening_hours": {
      "type": "string",
      "description": "Horarios de apertura (legacy)",
      "default": ""
    },
    "horario_dias": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "D\u00edas de disponibilidad",
      "default": []
    },
    "horario_apertura": {
      "type": "string",
      "description": "Hora de apertura (HH:MM)",
      "default": "09:00"
    },
    "horario_cierre": {
      "type": "string",
      "description": "Hora de cierre (HH:MM)",
      "default": "18:00"
    },
    "tarifa_base": {
      "type": "number",
      "description": "Tarifa base por hora/servicio",
      "default": 0
    },
    "facturacion": {
      "type": "string",
      "enum": [
        "autonomo",
        "sociedad",
        "otros"
      ],
      "description": "Tipo de facturaci\u00f3n",
      "default": "autonomo"
    },
    "formas_pago": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Formas de pago aceptadas",
      "default": []
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs de las fotos de realizaciones",
      "default": []
    },
    "imagen_principal": {
      "type": "string",
      "description": "URL de la imagen principal",
      "default": ""
    },
    "website": {
      "type": "string",
      "description": "Sitio web",
      "default": ""
    },
    "social_links": {
      "type": "object",
      "properties": {
        "facebook": {
          "type": "string",
          "default": ""
        },
        "instagram": {
          "type": "string",
          "default": ""
        },
        "linkedin": {
          "type": "string",
          "default": ""
        }
      },
      "description": "Enlaces de redes sociales",
      "default": {
        "facebook": "",
        "instagram": "",
        "linkedin": ""
      }
    },
    "price_range": {
      "type": "string",
      "enum": [
        "\u20ac",
        "\u20ac\u20ac",
        "\u20ac\u20ac\u20ac"
      ],
      "description": "Gama de precios",
      "default": "\u20ac\u20ac"
    },
    "average_rating": {
      "type": "number",
      "description": "Nota media",
      "default": 0
    },
    "total_reviews": {
      "type": "number",
      "description": "N\u00famero total de opiniones",
      "default": 0
    },
    "estado_perfil": {
      "type": "string",
      "enum": [
        "pendiente",
        "activo",
        "inactivo",
        "suspendido"
      ],
      "description": "Estado del perfil",
      "default": "pendiente"
    },
    "visible_en_busqueda": {
      "type": "boolean",
      "description": "Visible en b\u00fasquedas p\u00fablicas",
      "default": false
    },
    "onboarding_completed": {
      "type": "boolean",
      "description": "Quiz de onboarding completado",
      "default": false
    },
    "fecha_publicacion": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de publicaci\u00f3n del perfil"
    },
    "acepta_terminos": {
      "type": "boolean",
      "description": "Acepta t\u00e9rminos y condiciones",
      "default": false
    },
    "acepta_politica_privacidad": {
      "type": "boolean",
      "description": "Acepta pol\u00edtica de privacidad",
      "default": false
    },
    "consiente_contacto_clientes": {
      "type": "boolean",
      "description": "Consiente contacto de clientes",
      "default": false
    },
    "slug_publico": {
      "type": "string",
      "description": "Slug para URL p\u00fablica",
      "default": ""
    }
  },
  "required": [
    "user_id"
  ],
  "security": {
    "read": {
      "rule": "public"
    },
    "create": {
      "rule": "authenticated"
    },
    "update": {
      "rule": "resource.user_id == auth.user_id || auth.role == 'admin'"
    },
    "delete": {
      "rule": "auth.role == 'admin'"
    }
  }
}