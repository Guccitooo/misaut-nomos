
import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';
import Stripe from 'npm:stripe@14.10.0';

const stripe = new Stripe(Deno.env.get("STRIPE_SECRET_KEY"));
const webhookSecret = Deno.env.get("STRIPE_WEBHOOK_SECRET");

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        
        const signature = req.headers.get('stripe-signature');
        
        if (!signature) {
            return Response.json({ error: 'No signature provided' }, { status: 400 });
        }

        const body = await req.text();

        let event;
        try {
            event = await stripe.webhooks.constructEventAsync(
                body,
                signature,
                webhookSecret
            );
        } catch (err) {
            console.error('Webhook signature verification failed:', err.message);
            return Response.json({ error: 'Invalid signature' }, { status: 400 });
        }

        console.log('🔔 Webhook recibido:', event.type);

        // ✅ Handle checkout.session.completed (trial y pagos normales)
        if (event.type === 'checkout.session.completed') {
            const session = event.data.object;
            const metadata = session.metadata;
            const customerEmail = session.customer_email || metadata.email;
            
            console.log('✅ Checkout completado para:', customerEmail);
            console.log('📋 Metadata:', metadata);

            const today = new Date();
            const activityText = metadata.activity || "Sin especificar";
            const activityCategory = activityText.includes(":") 
                ? activityText.split(":")[0] 
                : activityText;

            // ✅ Verificar si es trial
            const isTrial = metadata.isTrial === "true" || 
                           session.subscription_data?.trial_period_days > 0;

            // ✅ NUEVO: Verificar si es reactivación
            const isReactivation = metadata.isReactivation === "true";

            // ✅ Obtener ID del plan desde metadata o usar default
            const planId = metadata.planId || "plan_monthly_trial";

            // Buscar el plan en la base de datos
            const plans = await base44.asServiceRole.entities.SubscriptionPlan.filter({
                plan_id: planId
            });
            const plan = plans[0];

            // Fecha de expiración según trial o no
            let expirationDate;
            let subscriptionStatus;
            
            if (isTrial) {
                expirationDate = new Date(today);
                expirationDate.setDate(expirationDate.getDate() + 7);
                subscriptionStatus = "en_prueba";
                console.log('🎁 Trial detectado - 7 días gratis');
            } else {
                expirationDate = new Date(today);
                
                if (plan) {
                    if (plan.duracion_dias === 30) {
                        expirationDate.setDate(expirationDate.getDate() + 30);
                    } else if (plan.duracion_dias === 90) {
                        expirationDate.setDate(expirationDate.getDate() + 90);
                    } else if (plan.duracion_dias === 365) {
                        expirationDate.setDate(expirationDate.getDate() + 365);
                    } else {
                        expirationDate.setMonth(expirationDate.getMonth() + 1);
                    }
                } else {
                    expirationDate.setMonth(expirationDate.getMonth() + 1);
                }
                
                subscriptionStatus = "actif";
                console.log('💳 Pago normal');
            }

            // Buscar usuario existente
            const existingUsers = await base44.asServiceRole.entities.User.filter({ 
                email: customerEmail 
            });

            let userId;
            if (existingUsers.length > 0) {
                userId = existingUsers[0].id;
                
                console.log(`📝 ${isReactivation ? 'REACTIVANDO' : 'Actualizando'} usuario ${customerEmail} con suscripción:`, subscriptionStatus);
                
                // ✅ Actualizar usuario
                await base44.asServiceRole.entities.User.update(existingUsers[0].id, {
                    full_name: metadata.fullName || existingUsers[0].full_name,
                    user_type: "professionnel",
                    phone: metadata.phone || existingUsers[0].phone,
                    city: metadata.address?.split(',').slice(-1)[0].trim() || existingUsers[0].city || "",
                    subscription_status: subscriptionStatus,
                    subscription_start_date: today.toISOString().split('T')[0],
                    subscription_end_date: expirationDate.toISOString().split('T')[0],
                    last_payment_date: today.toISOString().split('T')[0],
                });
                
                console.log(`✅ Usuario actualizado con subscription_status: ${subscriptionStatus}`);

                // ✅ CRÍTICO: Crear o actualizar registro en Subscription
                const existingSubscriptions = await base44.asServiceRole.entities.Subscription.filter({
                    user_id: userId
                });

                const subscriptionData = {
                    user_id: userId,
                    plan_id: planId,
                    plan_nombre: plan?.nombre || "Plan Mensual",
                    plan_precio: plan?.precio || 49,
                    fecha_inicio: today.toISOString(),
                    fecha_expiracion: expirationDate.toISOString(),
                    estado: isTrial ? "en_prueba" : "activo",
                    renovacion_automatica: true,
                    metodo_pago: "stripe",
                    fecha_ultima_renovacion: today.toISOString(),
                    stripe_subscription_id: session.subscription || "",
                    stripe_customer_id: session.customer || ""
                };

                if (existingSubscriptions.length > 0) {
                    await base44.asServiceRole.entities.Subscription.update(
                        existingSubscriptions[0].id,
                        subscriptionData
                    );
                    console.log(`✅ Suscripción ${isReactivation ? 'REACTIVADA' : 'actualizada'} para user_id: ${userId}`);
                } else {
                    await base44.asServiceRole.entities.Subscription.create(subscriptionData);
                    console.log(`✅ Suscripción creada para user_id: ${userId}`);
                }
                
            } else {
                console.log(`⚠️ Usuario no existe: ${customerEmail}`);
                await base44.asServiceRole.integrations.Core.SendEmail({
                    to: "admin@milautonomos.com",
                    subject: "✅ Pago confirmado - Crear cuenta milautonomos",
                    body: `Pago confirmado para nueva suscripción:

Email: ${customerEmail}
Nombre: ${metadata.fullName}
NIF/CIF: ${metadata.cifNif}
Teléfono: ${metadata.phone}
Actividad: ${activityText}
Dirección: ${metadata.address}
Es trial: ${isTrial ? 'SÍ - 7 días gratis' : 'NO - Pago directo'}
Estado suscripción: ${subscriptionStatus}

Stripe Customer ID: ${session.customer}
Stripe Subscription ID: ${session.subscription}`,
                    from_name: "milautonomos"
                });
            }

            // ✅ MEJORADO: Gestión de perfil profesional
            if (userId) {
                const existingProfiles = await base44.asServiceRole.entities.ProfessionalProfile.filter({
                    user_id: userId
                });

                if (existingProfiles.length === 0) {
                    // ✅ NUEVO USUARIO: Crear perfil en pendiente (debe completar quiz)
                    await base44.asServiceRole.entities.ProfessionalProfile.create({
                        user_id: userId,
                        business_name: metadata.fullName,
                        description: `Profesional recién registrado.`,
                        categories: [activityCategory],
                        service_area: metadata.address?.split(',').slice(-1)[0].trim() || "",
                        opening_hours: "A convenir",
                        cif_nif: metadata.cifNif || "",
                        telefono_contacto: metadata.phone || "",
                        email_contacto: customerEmail,
                        photos: [],
                        price_range: "€€",
                        average_rating: 0,
                        total_reviews: 0,
                        website: "",
                        social_links: {
                            facebook: "",
                            instagram: "",
                            linkedin: ""
                        },
                        estado_perfil: "pendiente",
                        visible_en_busqueda: false,  // ✅ NO visible hasta completar quiz
                        onboarding_completed: false
                    });
                    console.log(`✅ Perfil profesional creado en PENDIENTE (debe completar quiz)`);
                } else {
                    const profile = existingProfiles[0];
                    
                    // ✅ REACTIVACIÓN: Si ya completó el quiz, REACTIVAR perfil
                    if (profile.onboarding_completed) {
                        await base44.asServiceRole.entities.ProfessionalProfile.update(profile.id, {
                            estado_perfil: "activo",
                            visible_en_busqueda: true  // ✅ REACTIVAR visibilidad
                        });
                        console.log(`✅ ♻️ PERFIL REACTIVADO - Visible en búsquedas`);
                    } else {
                        // ✅ Perfil existe pero NO completado → Mantener pendiente
                        console.log(`⚠️ Perfil existe pero NO completado - Mantener pendiente`);
                    }
                }
            }

            // ✅ Email de confirmación
            const reactivationEmailBody = `Hola ${metadata.fullName},

¡Bienvenido de vuelta a milautonomos!

Tu suscripción ha sido reactivada correctamente.

📋 Detalles de tu suscripción:
- Plan: ${plan?.nombre || 'Plan Mensual'}
- Estado: ✅ ACTIVA
- Precio: ${plan?.precio || 49}€
- Fecha de renovación: ${expirationDate.toLocaleDateString('es-ES')}

✅ TU PERFIL YA ESTÁ VISIBLE EN BÚSQUEDAS
Los clientes pueden encontrarte y contactarte desde ahora mismo.

Puedes gestionar tu suscripción desde "Mi Perfil" > "Mi Suscripción".

Gracias por confiar en nosotros,
Equipo milautonomos`;

            const trialEmailBody = `Hola ${metadata.fullName},

¡Bienvenido${isReactivation ? ' de vuelta' : ''} a milautonomos!

Tu prueba gratuita de 7 días ha sido activada correctamente.

📋 Detalles de tu suscripción:
- Plan: Mensual (7 días gratis)
- Estado: ✅ ACTIVA - En periodo de prueba
- Duración de prueba: 7 días GRATIS
- Inicio: ${today.toLocaleDateString('es-ES')}
- Fin de prueba: ${expirationDate.toLocaleDateString('es-ES')}
- Tarjeta registrada: ✅ (NO se cobrará durante la prueba)

${isReactivation ? 
  '✅ TU PERFIL YA ESTÁ VISIBLE EN BÚSQUEDAS\nLos clientes pueden encontrarte desde ahora mismo.' :
  `⚠️ IMPORTANTE PRÓXIMO PASO:
Tu perfil NO está visible aún. Debes completar el quiz profesional para aparecer en búsquedas.

🚀 COMPLETA TU PERFIL AHORA:
1. Accede a tu panel de autónomo
2. Completa el quiz (5 minutos):
   - Datos profesionales
   - Ubicación y zona de trabajo
   - Fotos de tus trabajos
   - Tarifas y forma de pago
3. ¡Tu perfil se publicará automáticamente!`}

💰 Información de pago:
Si NO cancelas antes del ${expirationDate.toLocaleDateString('es-ES')}, se cobrará automáticamente 49€/mes.
Puedes cancelar en cualquier momento desde "Mi Suscripción" sin coste alguno durante el periodo de prueba.

Gracias por ${isReactivation ? 'volver a' : ''} unirte,
Equipo milautonomos`;

            const normalEmailBody = `Hola ${metadata.fullName},

¡Bienvenido${isReactivation ? ' de vuelta' : ''} a milautonomos!

Tu suscripción ha sido activada correctamente.

📋 Detalles de tu suscripción:
- Plan: ${plan?.nombre || 'Plan Mensual'}
- Estado: ✅ ACTIVA
- Precio: ${plan?.precio || 49}€
- Inicio: ${today.toLocaleDateString('es-ES')}
- Renovación: ${expirationDate.toLocaleDateString('es-ES')}

${isReactivation ? 
  '✅ TU PERFIL YA ESTÁ VISIBLE EN BÚSQUEDAS\nLos clientes pueden encontrarte y contactarte desde ahora mismo.' :
  `⚠️ IMPORTANTE: Tu perfil aún NO está visible.

🚀 PRÓXIMO PASO:
Completa tu perfil profesional (5 minutos) para aparecer en las búsquedas de clientes.

Una vez completes el quiz, tu perfil se publicará automáticamente y empezarás a recibir contactos.`}

Gracias,
Equipo milautonomos`;

            // ✅ Seleccionar email según tipo de activación
            let emailBody;
            let emailSubject;

            if (isReactivation) {
                emailBody = reactivationEmailBody;
                emailSubject = "✅ Tu suscripción ha sido reactivada - milautonomos";
            } else if (isTrial) {
                emailBody = trialEmailBody;
                emailSubject = "✅ Tu prueba gratuita está activa - Completa tu perfil";
            } else {
                emailBody = normalEmailBody;
                emailSubject = "✅ Bienvenido a milautonomos - Completa tu perfil";
            }

            await base44.asServiceRole.integrations.Core.SendEmail({
                to: customerEmail,
                subject: emailSubject,
                body: emailBody,
                from_name: "milautonomos"
            });

            console.log(`✅ Flujo completado para ${customerEmail} - ${isReactivation ? 'REACTIVACIÓN' : 'NUEVA SUSCRIPCIÓN'} - Estado: ${subscriptionStatus}`);
        }

        // ✅ Handle invoice.payment_succeeded (renovaciones mensuales)
        if (event.type === 'invoice.payment_succeeded') {
            const invoice = event.data.object;
            const customerEmail = invoice.customer_email;

            if (customerEmail) {
                const users = await base44.asServiceRole.entities.User.filter({ 
                    email: customerEmail 
                });

                if (users.length > 0) {
                    const userId = users[0].id;
                    const today = new Date();
                    const nextMonth = new Date(today);
                    nextMonth.setMonth(nextMonth.getMonth() + 1);

                    await base44.asServiceRole.entities.User.update(userId, {
                        subscription_status: "actif",
                        subscription_end_date: nextMonth.toISOString().split('T')[0],
                        last_payment_date: today.toISOString().split('T')[0],
                    });

                    // ✅ Actualizar también Subscription
                    const subscriptions = await base44.asServiceRole.entities.Subscription.filter({
                        user_id: userId
                    });

                    if (subscriptions.length > 0) {
                        await base44.asServiceRole.entities.Subscription.update(subscriptions[0].id, {
                            estado: "activo",
                            fecha_expiracion: nextMonth.toISOString(),
                            fecha_ultima_renovacion: today.toISOString()
                        });
                    }

                    console.log(`✅ Suscripción renovada para ${customerEmail}`);
                }
            }
        }

        // ✅ Handle customer.subscription.updated (cambios de estado)
        if (event.type === 'customer.subscription.updated') {
            const subscription = event.data.object;
            const customer = await stripe.customers.retrieve(subscription.customer);
            const customerEmail = customer.email;

            console.log('🔄 Suscripción actualizada:', subscription.status, 'para', customerEmail);

            if (customerEmail) {
                const users = await base44.asServiceRole.entities.User.filter({ 
                    email: customerEmail 
                });

                if (users.length > 0) {
                    const userId = users[0].id;
                    let newStatus;
                    let subscriptionEstado;
                    
                    switch (subscription.status) {
                        case 'trialing':
                            newStatus = 'en_prueba';
                            subscriptionEstado = 'en_prueba';
                            break;
                        case 'active':
                            newStatus = 'actif';
                            subscriptionEstado = 'activo';
                            break;
                        case 'past_due':
                            newStatus = 'suspendu';
                            subscriptionEstado = 'suspendu';
                            break;
                        case 'canceled':
                        case 'unpaid':
                            newStatus = 'annule';
                            subscriptionEstado = 'cancelado';
                            break;
                        default:
                            newStatus = subscription.status;
                            subscriptionEstado = subscription.status;
                    }

                    await base44.asServiceRole.entities.User.update(userId, {
                        subscription_status: newStatus,
                    });

                    // ✅ Actualizar también Subscription
                    const subscriptions = await base44.asServiceRole.entities.Subscription.filter({
                        user_id: userId
                    });

                    if (subscriptions.length > 0) {
                        await base44.asServiceRole.entities.Subscription.update(subscriptions[0].id, {
                            estado: subscriptionEstado
                        });
                    }

                    console.log(`✅ Estado actualizado a: ${newStatus}`);
                }
            }
        }

        // ✅ Handle customer.subscription.deleted (cancelaciones)
        if (event.type === 'customer.subscription.deleted') {
            const subscription = event.data.object;
            const customer = await stripe.customers.retrieve(subscription.customer);
            const customerEmail = customer.email;

            if (customerEmail) {
                const users = await base44.asServiceRole.entities.User.filter({ 
                    email: customerEmail 
                });

                if (users.length > 0) {
                    const userId = users[0].id;
                    
                    await base44.asServiceRole.entities.User.update(userId, {
                        subscription_status: "annule",
                    });

                    // ✅ Actualizar Subscription
                    const subscriptions = await base44.asServiceRole.entities.Subscription.filter({
                        user_id: userId
                    });

                    if (subscriptions.length > 0) {
                        await base44.asServiceRole.entities.Subscription.update(subscriptions[0].id, {
                            estado: "cancelado",
                            renovacion_automatica: false
                        });
                    }

                    // Ocultar perfil profesional
                    const profiles = await base44.asServiceRole.entities.ProfessionalProfile.filter({
                        user_id: userId
                    });

                    if (profiles.length > 0) {
                        await base44.asServiceRole.entities.ProfessionalProfile.update(profiles[0].id, {
                            visible_en_busqueda: false,
                            estado_perfil: "inactivo"
                        });
                        console.log(`❌ Perfil ocultado por cancelación de suscripción`);
                    }

                    await base44.asServiceRole.integrations.Core.SendEmail({
                        to: customerEmail,
                        subject: "Tu suscripción ha sido cancelada - milautonomos",
                        body: `Hola,

Tu suscripción a milautonomos ha sido cancelada.

Tu perfil ya no será visible en el listado de "Buscar Autónomos".

Si deseas reactivar tu suscripción, puedes hacerlo en cualquier momento desde tu panel de usuario.

Si tienes alguna pregunta, no dudes en contactarnos.

Gracias,
Equipo milautonomos`,
                        from_name: "milautonomos"
                    });

                    console.log(`❌ Suscripción cancelada para ${customerEmail}`);
                }
            }
        }

        // ✅ Handle invoice.payment_failed (pagos fallidos)
        if (event.type === 'invoice.payment_failed') {
            const invoice = event.data.object;
            const customerEmail = invoice.customer_email;

            if (customerEmail) {
                const users = await base44.asServiceRole.entities.User.filter({ 
                    email: customerEmail 
                });

                if (users.length > 0) {
                    const userId = users[0].id;
                    
                    await base44.asServiceRole.entities.User.update(userId, {
                        subscription_status: "suspendu",
                    });

                    // ✅ Actualizar Subscription
                    const subscriptions = await base44.asServiceRole.entities.Subscription.filter({
                        user_id: userId
                    });

                    if (subscriptions.length > 0) {
                        await base44.asServiceRole.entities.Subscription.update(subscriptions[0].id, {
                            estado: "suspendu"
                        });
                    }

                    const profiles = await base44.asServiceRole.entities.ProfessionalProfile.filter({
                        user_id: userId
                    });

                    if (profiles.length > 0) {
                        await base44.asServiceRole.entities.ProfessionalProfile.update(profiles[0].id, {
                            visible_en_busqueda: false,
                            estado_perfil: "suspendido"
                        });
                        console.log(`⚠️ Perfil ocultado por pago fallido`);
                    }

                    await base44.asServiceRole.integrations.Core.SendEmail({
                        to: customerEmail,
                        subject: "⚠️ Problema con tu pago - milautonomos",
                        body: `Hola,

Hemos tenido un problema al procesar tu pago mensual de milautonomos.

Tu suscripción ha sido suspendida temporalmente y tu perfil ya no es visible.

Por favor, actualiza tu método de pago para reactivarla.

Si tienes alguna pregunta, no dudes en contactarnos.

Gracias,
Equipo milautonomos`,
                        from_name: "milautonomos"
                    });

                    console.log(`⚠️ Pago fallido para ${customerEmail}`);
                }
            }
        }

        return Response.json({ received: true });
    } catch (error) {
        console.error('Webhook error:', error);
        return Response.json({
            error: 'Webhook processing failed',
            details: error.message
        }, { status: 500 });
    }
});
