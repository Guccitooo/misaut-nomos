import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        
        console.log('🔍 Verificando suscripciones expiradas...');
        
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        // ✅ CAMBIO: Verificar TODAS las suscripciones (no solo canceladas)
        const allSubs = await base44.asServiceRole.entities.Subscription.list();
        
        console.log(`📦 Suscripciones totales encontradas: ${allSubs.length}`);
        
        const results = {
            checked: 0,
            expired: 0,
            stillActive: 0,
            hidden: 0,
            errors: []
        };
        
        for (const sub of allSubs) {
            results.checked++;
            
            try {
                const expirationDate = new Date(sub.fecha_expiracion);
                expirationDate.setHours(0, 0, 0, 0);
                
                // ✅ Verificar si la suscripción ha expirado
                const hasExpired = expirationDate < today;
                
                // ✅ Estados que deberían estar ocultos
                const shouldBeHidden = 
                    hasExpired || 
                    sub.estado === "cancelado" || 
                    sub.estado === "finalizada" ||
                    sub.estado === "suspendu";
                
                if (shouldBeHidden) {
                    console.log(`⏰ Suscripción expirada/cancelada detectada: ${sub.user_id}`);
                    
                    // ✅ Actualizar estado si es necesario
                    if (hasExpired && sub.estado !== "finalizada") {
                        await base44.asServiceRole.entities.Subscription.update(sub.id, {
                            estado: "finalizada"
                        });
                        console.log(`✅ Estado actualizado a "finalizada"`);
                    }
                    
                    // ✅ Actualizar usuario
                    await base44.asServiceRole.entities.User.update(sub.user_id, {
                        subscription_status: "annule"
                    });
                    
                    // ✅ CRÍTICO: Ocultar perfil de búsquedas
                    const profiles = await base44.asServiceRole.entities.ProfessionalProfile.filter({
                        user_id: sub.user_id
                    });
                    
                    if (profiles.length > 0) {
                        const profile = profiles[0];
                        
                        // ✅ Solo actualizar si está visible (evitar actualizaciones innecesarias)
                        if (profile.visible_en_busqueda || profile.estado_perfil === "activo") {
                            await base44.asServiceRole.entities.ProfessionalProfile.update(profile.id, {
                                visible_en_busqueda: false,
                                estado_perfil: "inactivo"
                            });
                            console.log(`✅ Perfil ocultado: ${profile.business_name}`);
                            results.hidden++;
                        } else {
                            console.log(`⚪ Perfil ya estaba oculto: ${profile.business_name}`);
                        }
                    }
                    
                    // ✅ Enviar email de notificación solo si acaba de expirar
                    if (hasExpired && sub.estado !== "finalizada") {
                        const users = await base44.asServiceRole.entities.User.filter({ id: sub.user_id });
                        if (users.length > 0) {
                            try {
                                await base44.asServiceRole.integrations.Core.SendEmail({
                                    to: users[0].email,
                                    subject: "Tu suscripción ha finalizado - milautonomos",
                                    body: `Hola ${users[0].full_name || users[0].email},

Tu periodo de suscripción a milautonomos ha finalizado.

Tu perfil ya no es visible en las búsquedas públicas y no recibirás nuevos contactos de clientes.

¿Quieres volver a aparecer en las búsquedas?
👉 Reactiva tu plan desde tu panel de usuario: milautonomos.com/my-profile

Beneficios de reactivar tu suscripción:
✓ Aparece en las búsquedas
✓ Recibe contactos de clientes potenciales
✓ Gestiona tu perfil profesional
✓ Galería de fotos de trabajos
✓ Chat directo con clientes

Si tienes alguna pregunta, no dudes en contactarnos.

Gracias,
Equipo milautonomos`,
                                    from_name: "milautonomos"
                                });
                            } catch (emailError) {
                                console.error('Error enviando email:', emailError);
                            }
                        }
                    }
                    
                    results.expired++;
                } else {
                    // ✅ Suscripción activa - Verificar que el perfil ESTÉ visible
                    const activeStates = ["activo", "en_prueba", "trialing"];
                    if (activeStates.includes(sub.estado)) {
                        const profiles = await base44.asServiceRole.entities.ProfessionalProfile.filter({
                            user_id: sub.user_id
                        });
                        
                        if (profiles.length > 0 && profiles[0].onboarding_completed) {
                            // ✅ Asegurar que el perfil completado esté visible
                            if (!profiles[0].visible_en_busqueda || profiles[0].estado_perfil !== "activo") {
                                await base44.asServiceRole.entities.ProfessionalProfile.update(profiles[0].id, {
                                    visible_en_busqueda: true,
                                    estado_perfil: "activo"
                                });
                                console.log(`✅ Perfil activado (tenía suscripción activa): ${profiles[0].business_name}`);
                            }
                        }
                    }
                    
                    const daysLeft = Math.ceil((expirationDate - today) / (1000 * 60 * 60 * 24));
                    console.log(`⏳ Suscripción activa (${daysLeft} días restantes): ${sub.user_id}`);
                    results.stillActive++;
                }
            } catch (error) {
                console.error(`Error procesando suscripción ${sub.id}:`, error);
                results.errors.push({
                    subscription_id: sub.id,
                    error: error.message
                });
            }
        }
        
        console.log('✅ Verificación completada:', results);
        
        return Response.json({
            success: true,
            message: 'Verificación de suscripciones completada',
            results: results,
            timestamp: new Date().toISOString()
        });

    } catch (error) {
        console.error('Error verificando suscripciones:', error);
        return Response.json({
            error: 'Error al verificar suscripciones',
            details: error.message
        }, { status: 500 });
    }
});